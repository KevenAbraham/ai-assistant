FROM golang:1.25-alpine AS builder

# PortAudio requires CGO and dev headers.
RUN apk add --no-cache gcc musl-dev portaudio-dev

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=1 GOOS=linux go build -o /bin/daemon ./cmd/daemon

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata portaudio alsa-utils
COPY --from=builder /bin/daemon /bin/daemon

ENTRYPOINT ["/bin/daemon"]
