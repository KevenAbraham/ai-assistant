# PostgreSQL
DATABASE_URL=postgres://assistant:assistant@localhost:5432/assistant?sslmode=disable

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# HTTP server
HTTP_ADDR=:3000

# Logging
LOG_LEVEL=info

# Resources
SYSTEM_PROMPT_PATH=resources/system_prompt.txt

# Voice daemon
# Install whisper.cpp: brew install whisper-cpp && whisper-download-ggml-model base.en
# Run:                 whisper-server -m <model.bin> --port 9000
WHISPER_URL=http://localhost:9000
RECORD_SECONDS=30
SILENCE_THRESHOLD=500
SILENCE_DURATION_MS=1000
